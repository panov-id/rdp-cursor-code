FROM debian:trixie-slim

ENV DEBIAN_FRONTEND=noninteractive \
    DISPLAY=:1

ARG DESKTOP_USER
ARG DESKTOP_PASSWORD

RUN apt-get update && apt-get install -y --no-install-recommends \
    xfce4 \
    xfce4-terminal \
    tigervnc-standalone-server \
    tigervnc-common \
    tigervnc-tools \
    novnc \
    websockify \
    dbus-x11 \
    x11-xserver-utils \
    locales \
    sudo \
    curl \
    wget \
    nano \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN sed -i 's/^# *\(en_US.UTF-8\)/\1/' /etc/locale.gen \
    && sed -i 's/^# *\(ru_RU.UTF-8\)/\1/' /etc/locale.gen \
    && locale-gen

RUN useradd -m -s /bin/bash ${DESKTOP_USER} \
    && echo "${DESKTOP_USER}:${DESKTOP_PASSWORD}" | chpasswd \
    && usermod -aG sudo ${DESKTOP_USER}

# Configure TigerVNC xstartup with XFCE and US/RU keyboard layout (Alt+Shift switch)
RUN mkdir -p /home/${DESKTOP_USER}/.config/tigervnc \
    && echo '#!/bin/bash\n\
unset SESSION_MANAGER\n\
unset DBUS_SESSION_BUS_ADDRESS\n\
setxkbmap -layout "us,ru" -option "grp:alt_shift_toggle"\n\
exec startxfce4' > /home/${DESKTOP_USER}/.config/tigervnc/xstartup \
    && chmod +x /home/${DESKTOP_USER}/.config/tigervnc/xstartup \
    && chown -R ${DESKTOP_USER}:${DESKTOP_USER} /home/${DESKTOP_USER}/.config

RUN apt-get update && apt-get install -y --no-install-recommends \
    firefox-esr git ca-certificates \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN wget -O /tmp/cursor.deb "https://api2.cursor.sh/updates/download/golden/linux-x64-deb/cursor/2.6" && \
    apt-get update && \
    apt-get install -y /tmp/cursor.deb && \
    rm /tmp/cursor.deb && \
    rm -f /etc/apt/sources.list.d/cursor.list /etc/apt/sources.list.d/cursor.sources 2>/dev/null || true && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]