# PHP 8.4: current stable with security support until Dec 2028
FROM php:8.4-cli-bookworm

ENV DEBIAN_FRONTEND=noninteractive

# System deps and common PHP extensions for tests (e.g. intl, zip for Composer)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git unzip libzip-dev libicu-dev \
    && docker-php-ext-install -j$(nproc) zip intl \
    && rm -rf /var/lib/apt/lists/*

# Composer from official image
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Run as project dir (override when mounting)
WORKDIR /app

ENTRYPOINT ["php"]
CMD ["-v"]
